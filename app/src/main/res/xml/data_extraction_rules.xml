<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Android 12+ (API 31+).
   Excludes DataStore files to prevent score/theme manipulation via backup restore.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
